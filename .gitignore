# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Environment
.env

# Secrets (Earth Engine service-account key, etc.) — never commit key material.
# Keep the directory tracked (for the docker key mount) but ignore its contents.
/secrets/*
!/secrets/.gitkeep

# Docker volumes
db_data/
caddy_data/
caddy_config/

# Static files (collected/compiled)
staticfiles/
static/css/output.css

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Tailwind binary
tailwindcss-*

# Media (user-uploaded / generated reports)
media/
.claude/

# Internal planning / build scaffolding (not for public repo)
.planning/
.env.*
*.bak
*.bak.*
