# Open Water Accounting Platform - Environment Variables
#
# Copy this file to .env and fill in values:
#   cp .env.example .env
#
# Generate a secret key:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Django secret key (REQUIRED - generate a unique value, never commit it)
SECRET_KEY=change-me-generate-with-python3-c-import-secrets-print-secrets.token_urlsafe-50

# ---------------------------------------------------------------------------
# Database (defaults work for Docker Compose)
# ---------------------------------------------------------------------------

POSTGRES_DB=openh2o
POSTGRES_USER=openh2o
POSTGRES_PASSWORD=openh2o

# Override if connecting to an external database. Default connects to the
# Docker Compose db service:
# DATABASE_URL=postgis://openh2o:openh2o@db:5432/openh2o

# ---------------------------------------------------------------------------
# Django Settings Module
# ---------------------------------------------------------------------------

# For production (default — fail closed; needs a strong DB password +
# real ALLOWED_HOSTS, so a mis-copied deploy stops loudly, not in DEBUG):
DJANGO_SETTINGS_MODULE=config.settings.production

# For local development (uncomment, or run via make/pytest which pin --ds):
# DJANGO_SETTINGS_MODULE=config.settings.local

# ---------------------------------------------------------------------------
# Production Security (required when DJANGO_SETTINGS_MODULE=production)
# ---------------------------------------------------------------------------

# Comma-separated list of hostnames Django will serve
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated HTTPS origins trusted for CSRF (include https://)
# CSRF_TRUSTED_ORIGINS=https://openh2o.com

# ---------------------------------------------------------------------------
# Timezone
# ---------------------------------------------------------------------------

TIME_ZONE=America/Los_Angeles

# ---------------------------------------------------------------------------
# Email (optional, defaults to console output in development)
# ---------------------------------------------------------------------------

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=noreply@openh2o.com
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# ---------------------------------------------------------------------------
# Google OAuth (optional, enables "Sign in with Google")
# ---------------------------------------------------------------------------

# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# External Data Sync
# ---------------------------------------------------------------------------

# Set to True to use canned mock data instead of live public-API calls
# (no network on seed/sync). Default False = real data, matching the demo.
DATASYNC_MOCK_MODE=False

# ---------------------------------------------------------------------------
# OpenET data source
# ---------------------------------------------------------------------------

# OpenET REST API key (used when OPENET_MODE=api). Get one at https://etdata.org
# OPENET_API_KEY=
# OPENET_CACHE_DAYS=30
# OPENET_MONTHLY_BUDGET=400

# Which faucet OpenH2O uses for ET data:
#   api (default) = OpenET REST API, using OPENET_API_KEY above.
#   gee           = pull the SAME OpenET data from Google Earth Engine
#                   (large districts). Only set the GEE_* vars if you switch.
#                   Setup + honest cost guide: docs/earth-engine-tier-setup.md
OPENET_MODE=api
GEE_PROJECT=
GEE_SERVICE_ACCOUNT_EMAIL=
GEE_SERVICE_ACCOUNT_KEY_FILE=/run/secrets/gee-key.json